{
  "name": "thai-train-simulator",
  "version": "1.0.0",
  "description": "เกมจำลองการขับรถไฟเสมือนจริงของไทย",
  "author": "Kittiphong <Phutthipong.Ongrak@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-zip": "electron-builder --win dir && powershell -command \"Compress-Archive -Path dist\\win-unpacked\\* -DestinationPath dist\\update.zip -Force\""
  },
  "build": {
    "appId": "com.thaitrain.simulator",
    "publish": {
      "provider": "github",
      "owner": "Phutthipong2539",
      "repo": "thai-train-simulator"
    },
    "win": {
      "target": "dir"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "build/license.txt",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Thai Train Simulator"
    },
    "files": [
      "**/*",
      "!dist"
    ],
    "asar": true
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3"
  }
}
