{
  "name": "thai-train-simulator",
  "version": "1.0.8-z",
  "description": "เกมจำลองการขับรถไฟเสมือนจริงของไทย",
  "author": "Kittiphong <Phutthipong.Ongrak@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.thai.train.simulator",
    "asar": true,
    "win": {
      "target": ["nsis", "zip"],
      "icon": "icon.ico"
    },
    "files": [
      "**/*",
      "!dist",
      "!*.zip",
      "!package-lock.json"
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
